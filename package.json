{
  "name": "minilib-backend",
  "version": "1.0.0",
  "description": "API REST MiniLib — Node.js / Express",
  "type": "module",
  "private": true,
  "main": "src/app.js",
  "scripts": {
    "lib-install": "pnpm uninstall @hendec/types; pnpm install @hendec/types; pnpm uninstall @hendec/backend; pnpm install @hendec/backend",
    "build": "tsc -p ./tsconfig.build.json",
    "start": "node dist/app.js",
    "dev": "npm run lib-install && tsx --watch --env-file=.env src/app.ts",
    "test": "echo \"Tests à venir\""
  },
  "dependencies": {
    "@hendec/backend": "^0.0.1",
    "@hendec/types": "^0.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
